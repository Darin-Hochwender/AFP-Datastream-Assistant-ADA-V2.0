<Window x:Class="AFPEngineer_Explorer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AFP Insight - Systems Engineer Edition" Height="700" Width="1100"
        Background="#F0F0F0">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#FFFFFF" BorderBrush="#CCCCCC" BorderThickness="0,0,1,0">
            <DockPanel Margin="15">
                <Button x:Name="OpenFileBtn" 
                        Content="📁 Open AFP File" 
                        Click="OpenFile_Click" 
                        DockPanel.Dock="Top" 
                        Height="40" 
                        FontWeight="Bold"
                        Background="#007ACC" 
                        Foreground="White"
                        Margin="0,0,0,15"/>

                <TextBlock Text="Structured Fields (MO:DCA)" DockPanel.Dock="Top" FontWeight="Bold" Margin="0,0,0,5"/>

                <TreeView x:Name="AfpTreeView" Background="#F9F9F9"/>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="200"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="FieldNameTxt" Text="Select a field to begin..." FontSize="18" Margin="0,0,0,10"/>

            <Border Grid.Row="1" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                <ScrollViewer>
                    <TextBlock x:Name="HexDataTxt" FontFamily="Consolas" TextWrapping="Wrap" Text="Field details will appear here."/>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="2" Background="#444" CornerRadius="5" Padding="20">
                <Viewbox Stretch="Uniform">
                    <Canvas x:Name="PageCanvas" Width="816" Height="1056" Background="White">
                    </Canvas>
                </Viewbox>
            </Border>
        </Grid>
    </Grid>
</Window>